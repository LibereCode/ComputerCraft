{
    "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
    "completion": {
        "autoRequire": true,
        "autoRequireNamingConvention": "camel-case",
        "callSnippet": true,
        "postfix": "@"
    },
    "diagnostics": {
        "diagnosticInterval": 123,
        "globals": [],
        "disable": [
            "undefined-global"
        ]
    },
    "doc": {
        "syntax": "md"
    },
    "runtime": {
        "version": "LuaLatest",
        "requirePattern": [
            "?.lua",
            "?/init.lua"
        ]
    }
}
